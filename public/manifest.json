          "type": "image/png"
        },
        {
          "src": "images/touch/ie-96x96.png",
          "sizes": "96x96",
          "type": "image/png"
        },
        {
            "src": "images/touch/ie-144x144.png",
            "sizes": "144x144",
            "type": "image/png"
        },
        {
            "src": "images/touch/ie-310x310.png",
            "sizes": "310x310",
            "type": "image/png",
            "purpose": "any maskable"
        }
